{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Compila C",
            "type": "process",
            "command": "C:/msys64/mingw64/bin/gcc.exe",
            "args": [
                "-g",
                "main.c",
                "funzioni.c",
                "-o",
                "main.exe"
            ],
            "options": {
                "cwd": "${workspaceFolder}",
                "shell": {
                    "executable": "cmd.exe",
                    "args": ["/c"]
                }
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$gcc"],
            "detail": "Compila tutti i file C usando GCC di MSYS2 MinGW64"
        }
    ]
}
